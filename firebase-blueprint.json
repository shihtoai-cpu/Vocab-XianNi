{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Individual user progress and stats",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "avatarSize": { "type": "number" },
        "avatarX": { "type": "number" },
        "avatarY": { "type": "number" },
        "totalExp": { "type": "number" },
        "totalAncientExp": { "type": "number" },
        "jing": { "type": "number" },
        "qi": { "type": "number" },
        "shen": { "type": "number" },
        "maxJing": { "type": "number" },
        "maxQi": { "type": "number" },
        "maxShen": { "type": "number" },
        "lastRefresh": { "type": "number" },
        "realm": { "type": "string" },
        "rotations": { "type": "number" },
        "isMaster": { "type": "boolean" },
        "recoveryPw": { "type": "string" },
        "items": {
          "type": "object",
          "properties": {
            "bloodPill": { "type": "number" },
            "qiPill": { "type": "number" },
            "spiritPill": { "type": "number" },
            "spiritJade": { "type": "number" }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "rounds": { "type": "number" },
            "lastDate": { "type": "string" },
            "wordStats": { "type": "object" },
            "wordHistory": { "type": "object" }
          }
        }
      },
      "required": ["name", "stats"]
    },
    "GlobalConfig": {
      "title": "App Configuration",
      "description": "Global settings, words, and batches",
      "type": "object",
      "properties": {
        "words": { "type": "array" },
        "batches": { "type": "array" },
        "settings": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents stored by Auth UID"
    },
    "/global/config": {
      "schema": "GlobalConfig",
      "description": "Global application configuration"
    }
  }
}
