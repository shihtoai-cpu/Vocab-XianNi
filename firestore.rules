rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() <= 64 &&
             data.exp is number &&
             data.stats is map;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow listing for Hall of Fame
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Global Config
    match /global/config {
      allow read: if true; // Allow landing page to see basic app config if needed
      allow write: if isSignedIn(); 
    }
  }
}
