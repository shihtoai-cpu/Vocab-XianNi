rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSovereign() {
      return isSignedIn() && (
        request.auth.token.email == "shihto.ai@gmail.com" || 
        request.auth.token.email == "test@xianni.auth"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() <= 64 &&
             data.exp is number &&
             data.stats is map;
    }

    // Users collection
    match /users/{userId} {
      allow list: if true; // 允許山門前感應道友氣息 (Public list for selection)
      allow get: if true;
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isSovereign();
      allow delete: if isSovereign(); // 僅限主宰可焚毀修士名冊
    }

    // Global Config
    match /global/config {
      allow read: if true; 
      allow write: if isSovereign(); // 僅限主宰可修改天道設定與仙冊
    }
  }
}
