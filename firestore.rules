rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSovereign() {
      return isSignedIn() && (
        request.auth.token.email == "shihto.ai@gmail.com" || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMaster == true
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || isSovereign();
    }

    match /global/{allPaths=**} {
      allow read: if true;
      allow write: if isSovereign();
    }
  }
}
