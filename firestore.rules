rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 預設拒絕
    match /{document=**} {
      allow read, write: if false;
    }

    // 修士存檔：公開讀取以利門戶展示，本人或主宰可寫
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId || 
        (request.auth != null && (
          request.auth.token.email == "shihto.ai@gmail.com" || 
          request.auth.uid == "DqXGrDEHqxVXc9rXI77pWAndCbl2" ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMaster == true
        ));
    }

    // 全域配置：公開讀取，僅主宰可寫
    match /global/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == "shihto.ai@gmail.com" || 
        request.auth.uid == "DqXGrDEHqxVXc9rXI77pWAndCbl2" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMaster == true
      );
    }
  }
}
